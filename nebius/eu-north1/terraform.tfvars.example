# Example configuration for Nebius Kubernetes cluster in eu-north1
# Copy this file to terraform.tfvars and replace with your actual values

# Your Nebius project ID
project_id = "project-xxxxx"

# The subnet ID where the cluster will be deployed
subnet_id = "vpcsubnet-xxxxx"

# The ID of the viewers group for Nebius Container Registry access
# Find this in your Nebius console under IAM -> Groups
viewers_group_id = "group-xxxxx"

# Name for your Kubernetes cluster
cluster_name = "saturn-cluster"

# InfiniBand fabric for H100 instances
# Available fabrics: fabric-2, fabric-3, fabric-4, fabric-6
# H200 instances always use fabric-7
h100_infiniband_fabric = "fabric-6"

saturn_cloud_provider          = "nebius"
saturn_region                  = "eu-north1"
saturn_availability_zone       = "eu-north1"
saturn_domain          = "example.saturnenterprise.io"
saturn_bucket_name     = "saturn-bucket-name"
saturn_admin_email     = "admin@example.com"
saturn_customer_name   = "example-customer"
saturn_base_url        = "https://app.example.saturnenterprise.io"
saturn_ssh_domain      = "ssh.example.saturnenterprise.io"
saturn_bootstrap_token = "your-bootstrap-token-here"
saturn_image_build_node_role   = "gpu-h100-sxm-1gpu-20vcpu-160gb"

# Saturn Cloud Instance Configuration for eu-north1 (H100 and H200 only)
saturn_instance_config = {
  default_cpu = "nebius-gpu-h100-sxm-1gpu-20vcpu-160gb"
  default_gpu = "nebius-gpu-h200-sxm-1gpu-26vcpu-220gb"
  sizes = [
    # Nebius H100 GPU Instances (use configurable fabric, default: fabric-6)
    {
      name          = "nebius-gpu-h100-sxm-1gpu-20vcpu-160gb"
      cores         = 20
      memory        = "160Gi"
      gpu           = 1
      gpu_type      = "H100"
      hardware_type = "NVIDIA"
      display_name  = "gpu-h100-sxm-1gpu-20vcpu-160gb"
      node_role     = "gpu-h100-sxm-1gpu-20vcpu-160gb"
    },
    {
      name          = "nebius-gpu-h100-sxm-8gpu-160vcpu-1280gb"
      cores         = 160
      memory        = "1280Gi"
      gpu           = 8
      gpu_type      = "H100"
      hardware_type = "NVIDIA"
      display_name  = "gpu-h100-sxm-8gpu-160vcpu-1280gb"
      node_role     = "gpu-h100-sxm-8gpu-160vcpu-1280gb"
      description   = "8xH100 instance with InfiniBand"
    },
    # Nebius H200 GPU Instances (always use fabric-7)
    {
      name          = "nebius-gpu-h200-sxm-1gpu-26vcpu-220gb"
      cores         = 26
      memory        = "220Gi"
      gpu           = 1
      gpu_type      = "H200"
      hardware_type = "NVIDIA"
      display_name  = "gpu-h200-sxm-1gpu-26vcpu-220gb"
      node_role     = "gpu-h200-sxm-1gpu-26vcpu-220gb"
    },
    {
      name          = "nebius-gpu-h200-sxm-8gpu-208vcpu-1760gb"
      cores         = 208
      memory        = "1760Gi"
      gpu           = 8
      gpu_type      = "H200"
      hardware_type = "NVIDIA"
      display_name  = "gpu-h200-sxm-8gpu-208vcpu-1760gb"
      node_role     = "gpu-h200-sxm-8gpu-208vcpu-1760gb"
      description   = "8xH200 instance with InfiniBand on fabric-7"
    }
  ]
}
